generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Participant {
  id        String    @id @default(cuid())
  name      String    @unique
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  testSectionId String      @unique
  mentalFatigue   Int
  focusLevel      Int
  physicalFatigue Int
  fatigueLabel    Int
  wpm             Float
  errorRate       Float
  targetText      String
  typedText       String
  keystrokes    Keystroke[]
}

model Keystroke {
  id          String  @id @default(cuid())
  sessionId   String
  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key         String
  pressTime   Float
  releaseTime Float
}
